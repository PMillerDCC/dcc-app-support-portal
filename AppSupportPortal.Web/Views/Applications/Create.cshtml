@model AppSupportPortal.Web.Models.ApplicationViewModel

<h2>Create Application</h2>

<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="ApplicationName" class="form-label"></label>
        <input asp-for="ApplicationName" class="form-control" />
        <span asp-validation-for="ApplicationName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ApplicationDescription" class="form-label"></label>
        <textarea asp-for="ApplicationDescription" class="form-control"></textarea>
        <span asp-validation-for="ApplicationDescription" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ApplicationDeveloper" class="form-label"></label>
        <input asp-for="ApplicationDeveloper" class="form-control" />
        <span asp-validation-for="ApplicationDeveloper" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ServerId" class="form-label">Server</label>
        <select asp-for="ServerId" asp-items="@(new SelectList(Model.Servers, "ServerId", "ServerName"))" class="form-select"></select>
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
