@model AppSupportPortal.Web.Models.ApplicationViewModel

<h2>Create Application</h2>
<div asp-validation-summary="All" class="text-danger"></div>
<form asp-action="Create" method="post">
    <div class="mb-3">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Description"></label>
        <input asp-for="Description" class="form-control" />
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ServerId">Server</label>
        <select asp-for="ServerId"
                asp-items="@(new SelectList(ViewBag.Servers, "Id", "Name"))"
                class="form-select">
            <option value="">-- Select Server --</option>
        </select>
        <span asp-validation-for="ServerId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
