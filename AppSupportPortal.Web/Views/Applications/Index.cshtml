@model IEnumerable<AppSupportPortal.Web.Models.ApplicationViewModel>

<h2>Applications</h2>

@{
    var role = TempData["CurrentRole"]?.ToString() ?? "Regular";
    TempData.Keep("CurrentRole");
}

@if (role == "Admin")
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Create New</a>
    </p>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Description</th>
            <th>Server Name</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var a in Model)
        {
            <tr>
                <td>@a.Name</td>
                <td>@a.Description</td>
                <td>@a.ServerName</td>
                <td>
                    <a asp-action="Details" asp-route-id="@a.Id" class="btn btn-info btn-sm">Details</a>

                    @if (role == "Admin")
                    {
                        <a asp-action="Edit" asp-route-id="@a.Id" class="btn btn-warning btn-sm">Edit</a>
                        <a asp-action="Delete" asp-route-id="@a.Id" class="btn btn-danger btn-sm">Delete</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
