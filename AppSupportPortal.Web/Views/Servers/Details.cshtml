@model AppSupportPortal.Web.Models.ServerViewModel

<h2>Server Details</h2>
@{
    var role = TempData["CurrentRole"]?.ToString() ?? "Regular";
    TempData.Keep("CurrentRole");
}
<div class="card">
    <div class="card-body">
        <h4>@Model.Name</h4>
        <p><strong>Description:</strong> @Model.Description</p>
        <p><strong>Host Name:</strong> @Model.Hostname</p>
        <p><strong>IP Address:</strong> @Model.IPAddress</p>
    </div>
</div>

<a asp-action="Index" class="btn btn-secondary mt-3">Back to List</a>

@if (role == "Admin")
{
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Delete</a>
}


