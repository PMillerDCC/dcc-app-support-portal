@model ServerViewModel
@{
    ViewData["Title"] = "Edit Server";
}

<h2>Edit Server</h2>

<form asp-action="Edit" method="post" class="mt-3">

    <input type="hidden" asp-for="ServerId" />

    <div class="mb-3">
        <label asp-for="ServerName" class="form-label"></label>
        <input asp-for="ServerName" class="form-control" />
        <span asp-validation-for="ServerName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ServerDescription" class="form-label"></label>
        <textarea asp-for="ServerDescription" class="form-control"></textarea>
        <span asp-validation-for="ServerDescription" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ServerStatus" class="form-label"></label>
        <input asp-for="ServerStatus" class="form-control" />
        <span asp-validation-for="ServerStatus" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
