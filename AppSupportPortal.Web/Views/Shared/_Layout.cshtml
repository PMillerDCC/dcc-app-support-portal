<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AppSupportPortal.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AppSupportPortal.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">App Support Portal</a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Applications" asp-action="Index">Applications</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Servers" asp-action="Index">Servers</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Users" asp-action="Index">Users</a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" asp-controller="Notes" asp-action="Index">Notes</a>
                </li>

            </ul>
                    @{
                        var role = TempData["CurrentRole"]?.ToString() ?? "Regular";
                        TempData.Keep("CurrentRole");
                    }

                    <form asp-controller="Home" asp-action="SetRole" method="post" class="d-flex">
                        <select name="role" class="form-select form-select-sm" onchange="this.form.submit()">
                            <option value="Regular" selected="@(role == "Regular")">Regular</option>
                            <option value="Admin" selected="@(role == "Admin")">Admin</option>
                        </select>
                    </form>
        </div>
            </div>
        </nav>
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success text-center m-2">
                @TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger text-center m-2">
                @TempData["Error"]
            </div>
        }
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - AppSupportPortal.Web - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
