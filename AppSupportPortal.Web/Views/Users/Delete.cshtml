@model AppSupportPortal.Web.Models.UserViewModel

<h2>Delete User</h2>

<div class="alert alert-warning">
    Are you sure you want to delete <strong>@Model.DisplayName</strong>?
</div>

<div class="card mb-3">
    <div class="card-body">
        <p><strong>User Name:</strong> @Model.UserName</p>
        <p><strong>Display Name:</strong> @Model.DisplayName</p>
        <p><strong>Email:</strong> @Model.Email</p>
        <p><strong>Role:</strong> @Model.RoleName</p>
    </div>
</div>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>