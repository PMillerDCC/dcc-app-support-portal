@model AppSupportPortal.Web.Models.UserViewModel

<h2>User Details</h2>
@{
    var role = TempData["CurrentRole"]?.ToString() ?? "Regular";
    TempData.Keep("CurrentRole");
}
<div class="card">
    <div class="card-body">
        <p><strong>User Name:</strong> @Model.UserName</p>
        <p><strong>Display Name:</strong> @Model.DisplayName</p>
        <p><strong>Email:</strong> @Model.Email</p>
        <p><strong>Role:</strong> @Model.RoleName</p>
    </div>
</div>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning mt-3">Edit</a>
<a asp-action="Index" class="btn btn-secondary mt-3">Back to List</a>