@model AppSupportPortal.Web.Models.UserViewModel

<h2>User Details</h2>

<div class="card">
    <div class="card-body">
        <h4>@Model.DisplayName (@Model.UserName)</h4>

        <p><strong>Email:</strong> @Model.Email</p>
        <p><strong>Role:</strong> @Model.RoleName</p>
        <p><strong>Created:</strong> @Model.CreatedAt.ToString("dd MMM yyyy HH:mm")</p>
    </div>
</div>

<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning mt-3">Edit</a>
<a asp-action="Index" class="btn btn-secondary mt-3">Back to List</a>